{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config.schema.json",
  "title": "beval Configuration",
  "description": "Schema for beval eval.config.yaml configuration file per SPEC §13.",
  "type": "object",
  "required": ["eval"],
  "additionalProperties": false,
  "properties": {
    "eval": {
      "$ref": "#/$defs/EvalConfig",
      "description": "Top-level evaluation configuration."
    }
  },
  "$defs": {
    "EvaluationMode": {
      "type": "string",
      "enum": ["dev", "dev+process", "validation", "monitoring"],
      "description": "Evaluation mode controlling which grader layers are active."
    },
    "Score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "A normalized score in the range 0.0 to 1.0."
    },
    "EvalConfig": {
      "type": "object",
      "description": "Root evaluation configuration block.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "$ref": "#/$defs/EvaluationMode",
          "description": "Default evaluation mode."
        },
        "thresholds": {
          "$ref": "#/$defs/Thresholds",
          "description": "Pass/fail threshold configuration."
        },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/MetricDefinition" },
          "description": "Metric category definitions with display metadata."
        },
        "metric_weights": {
          "type": "object",
          "description": "Optional per-metric weights for weighted scoring. Unspecified metrics default to 1.0.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        },
        "output": {
          "$ref": "#/$defs/OutputConfig",
          "description": "Results output configuration."
        },
        "judge": {
          "$ref": "#/$defs/JudgeConfig",
          "description": "Judge configuration. See spec/judges.spec.md §14."
        },
        "tracing": {
          "$ref": "#/$defs/TracingConfig",
          "description": "OpenTelemetry tracing configuration."
        },
        "trials": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Number of trial executions per case."
        },
        "trial_aggregation": {
          "type": "string",
          "enum": ["mean", "median", "pass_at_k", "pass_all_k", "min"],
          "default": "mean",
          "description": "Strategy for aggregating scores across trials."
        },
        "cache": {
          "$ref": "#/$defs/CacheConfig",
          "description": "Response caching configuration."
        },
        "agents": {
          "$ref": "#/$defs/AgentsConfig",
          "description": "Agent definition and selection configuration. See SPEC §13."
        }
      }
    },
    "AgentsConfig": {
      "type": "object",
      "description": "Agent configuration for connecting to systems under test.",
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "description": "Name of the default agent from the definitions array."
        },
        "definitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentDefinition" },
          "description": "Agent definitions available for this project."
        }
      }
    },
    "AgentDefinition": {
      "type": "object",
      "description": "Inline agent definition. Same schema as standalone agent YAML files (agent.schema.json).",
      "required": ["name", "protocol", "connection"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique agent identifier."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description."
        },
        "protocol": {
          "type": "string",
          "enum": ["acp", "a2a", "custom"],
          "description": "Connection protocol type."
        },
        "connection": {
          "type": "object",
          "description": "Protocol-specific connection parameters. Validated per-protocol via allOf conditionals below."
        },
        "timeout": {
          "type": "number",
          "minimum": 0,
          "default": 30,
          "description": "Request timeout in seconds."
        },
        "retry": {
          "type": "object",
          "description": "Retry policy.",
          "additionalProperties": false,
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "backoff": {
              "type": "number",
              "minimum": 0,
              "default": 1.0
            }
          }
        },
        "env": {
          "type": "object",
          "description": "Environment variable bindings using ${VAR_NAME} syntax.",
          "additionalProperties": { "type": "string" }
        },
        "metadata": {
          "type": "object",
          "description": "Open-ended key-value pairs surfaced in results.",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "protocol": { "const": "acp" } }
          },
          "then": {
            "properties": {
              "connection": { "$ref": "agent.schema.json#/$defs/ACPConnection" }
            }
          }
        },
        {
          "if": {
            "properties": { "protocol": { "const": "a2a" } }
          },
          "then": {
            "properties": {
              "connection": { "$ref": "agent.schema.json#/$defs/A2AConnection" }
            }
          }
        },
        {
          "if": {
            "properties": { "protocol": { "const": "custom" } }
          },
          "then": {
            "properties": {
              "connection": { "$ref": "agent.schema.json#/$defs/CustomConnection" }
            }
          }
        }
      ]
    },
    "Thresholds": {
      "type": "object",
      "description": "Score thresholds for pass/fail derivation.",
      "additionalProperties": false,
      "properties": {
        "grade_pass": {
          "$ref": "#/$defs/Score",
          "default": 0.5,
          "description": "A grade passes when its score exceeds this value."
        },
        "case_pass": {
          "$ref": "#/$defs/Score",
          "default": 0.7,
          "description": "A case passes when its overall score meets or exceeds this value."
        }
      }
    },
    "MetricDefinition": {
      "type": "object",
      "description": "Definition of a metric category with display metadata.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Metric category name (e.g., latency, quality)."
        },
        "icon": {
          "type": "string",
          "description": "Display icon or emoji for this metric."
        }
      }
    },
    "OutputConfig": {
      "type": "object",
      "description": "Configuration for results output.",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "type": "string",
          "default": "eval_results",
          "description": "Directory for results output files."
        },
        "format": {
          "type": "string",
          "enum": ["json", "jsonl"],
          "default": "json",
          "description": "Output file format."
        },
        "console": {
          "type": "boolean",
          "default": true,
          "description": "Whether to print results to console."
        }
      }
    },
    "JudgeConfig": {
      "type": "object",
      "description": "Judge configuration. See spec/judges.spec.md §14.",
      "required": ["protocol"],
      "additionalProperties": false,
      "properties": {
        "protocol": {
          "type": "string",
          "enum": ["acp", "openai"],
          "description": "Judge backend protocol."
        },
        "connection": {
          "type": "object",
          "description": "ACP connection parameters (protocol: acp only)."
        },
        "timeout": {
          "type": "number",
          "minimum": 0,
          "default": 30
        },
        "model": {
          "type": "string",
          "description": "Model identifier (protocol: openai only)."
        },
        "api_key": {
          "type": "string",
          "description": "API key reference, e.g. ${OPENAI_API_KEY} (protocol: openai only)."
        },
        "base_url": {
          "type": "string",
          "description": "Base URL override (protocol: openai only)."
        },
        "auth": {
          "type": "string",
          "enum": ["entra_id"],
          "description": "Auth method override. 'entra_id' uses Azure DefaultAzureCredential (protocol: openai only)."
        },
        "max_answer_chars": {
          "type": "integer",
          "minimum": 1,
          "description": "Truncation limit for subject answer in judge prompt (protocol: openai only)."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "protocol": { "const": "acp" } } },
          "then": { "required": ["connection"] }
        },
        {
          "if": { "properties": { "protocol": { "const": "openai" } } },
          "then": { "required": ["model"] }
        }
      ]
    },
    "TracingConfig": {
      "type": "object",
      "description": "OpenTelemetry tracing configuration.",
      "additionalProperties": false,
      "properties": {
        "in_memory": {
          "type": "boolean",
          "default": true,
          "description": "Enable in-memory span exporter for process graders. Always true for offline evaluation."
        },
        "cloud": {
          "$ref": "#/$defs/CloudTracingConfig",
          "description": "Cloud trace export configuration."
        }
      }
    },
    "CloudTracingConfig": {
      "type": "object",
      "description": "Configuration for exporting traces to a cloud backend.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether cloud trace export is enabled."
        },
        "connection_string": {
          "type": "string",
          "description": "Connection string for the cloud trace backend. Typically resolved from an environment variable."
        }
      }
    },
    "CacheConfig": {
      "type": "object",
      "description": "Response caching configuration for system and judge outputs.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether response caching is enabled."
        },
        "dir": {
          "type": "string",
          "default": ".eval_cache",
          "description": "Directory for cache storage."
        }
      }
    }
  }
}
